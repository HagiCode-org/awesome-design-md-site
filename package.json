{
  "name": "awesome-design-md-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.10.1",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port ${PORT_WEBSITE:-4321}",
    "start": "astro dev --host 0.0.0.0",
    "build": "npm run sync:footer-sites && astro build",
    "preview": "astro preview --host 0.0.0.0 --port ${PORT_WEBSITE:-4321}",
    "astro": "astro",
    "sync:footer-sites": "node ./scripts/fetch-sites-snapshot.mjs",
    "test": "vitest run",
    "typecheck": "astro check",
    "clean": "rm -rf .astro dist"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/react": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "astro": "^6.0.7",
    "astro-robots-txt": "^1.0.0",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "typescript": "~5.3.0",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
