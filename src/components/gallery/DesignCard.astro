---
import type { AwesomeDesignEntry } from '@/lib/content/awesomeDesignCatalog';
import { interpolate } from '@/i18n';
import { localeCopy, toLocalePath, type SupportedLocale } from '@/config/site';

interface Props {
  entry: AwesomeDesignEntry;
  locale?: SupportedLocale;
}

const { entry, locale = 'en' } = Astro.props;
const href = toLocalePath(`/designs/${entry.slug}/`, locale);
const copy = localeCopy[locale];
const ariaLabel = interpolate(copy.common.card.openDetails, { title: entry.title });
---

<a
  class="design-card shell-panel"
  data-design-card
  data-slug={entry.slug}
  data-search-text={entry.searchText}
  href={href}
  aria-label={ariaLabel}
>
  <div class="design-card-preview">
    <iframe
      class="design-card-frame"
      src="about:blank"
      data-preview-frame
      data-light-src={entry.preview.lightUrl}
      data-dark-src={entry.preview.darkUrl}
      title={`${entry.title} preview`}
      loading="lazy"
      sandbox="allow-same-origin allow-scripts"
    />
  </div>

  <div class="design-card-body">
    <div class="design-card-topline">
      <span>{copy.card.preview}</span>
    </div>
    <h2>{entry.title}</h2>
    <div class="design-card-tags">
      <span>{entry.preview.hasDedicatedDark ? copy.card.lightDark : copy.card.fallbackAware}</span>
    </div>
  </div>
</a>
