---
import { localeCopy, type SupportedLocale } from '@/config/site';

interface Props {
  readmeHtml: string;
  designHtml: string;
  designMarkdown: string;
  designDownloadUrl: string;
  locale?: SupportedLocale;
}

const {
  readmeHtml,
  designHtml,
  designMarkdown,
  designDownloadUrl,
  locale = 'en',
} = Astro.props;
const copy = localeCopy[locale].documents;
---

<section
  class="detail-documents"
  data-document-tabs
  data-copy-design-label={copy.copyDesign}
  data-copied-label={copy.copied}
  data-copy-failed-label={copy.copyFailed}
>
  <div class="detail-documents-head">
    <div>
      <p class="detail-kicker">{copy.kicker}</p>
      <h2>{copy.heading}</h2>
    </div>
    <div class="detail-doc-controls">
      <div class="detail-tab-list" role="tablist" aria-label={copy.tabListLabel}>
        <button type="button" class="detail-tab is-active" data-doc-tab="readme" aria-selected="true">
          {copy.readme}
        </button>
        <button type="button" class="detail-tab" data-doc-tab="design" aria-selected="false">
          {copy.design}
        </button>
      </div>
      <button
        type="button"
        class="detail-copy-button"
        data-copy-design
        disabled
        aria-disabled="true"
        title={copy.copyDesignTitle}
      >
        {copy.copyDesign}
      </button>
      <a
        class="detail-copy-button"
        data-download-design
        href={designDownloadUrl}
        download="DESIGN.md"
        title={copy.downloadDesignTitle}
        aria-hidden="true"
        tabindex="-1"
      >
        {copy.downloadDesign}
      </a>
    </div>
  </div>

  <div class="detail-doc-panels">
    <section class="detail-doc-panel is-active" data-doc-panel="readme">
      <div class="markdown-shell document-copy" set:html={readmeHtml} />
    </section>
    <section class="detail-doc-panel" data-doc-panel="design" hidden>
      <div class="markdown-shell document-copy" set:html={designHtml} />
    </section>
  </div>

  <textarea hidden readonly data-design-markdown>{designMarkdown}</textarea>
</section>

<script>
  import { initializeDocumentTabs } from '@/components/gallery/document-tabs';

  initializeDocumentTabs();
</script>
