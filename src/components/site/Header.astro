---
import ThemeToggle from '@/components/theme/ThemeToggle';
import {
  getLocaleHomePath,
  localeCopy,
  type LanguageLink,
  type NavItem,
  type SupportedLocale,
} from '@/config/site';

interface Props {
  nav: NavItem[];
  lang?: SupportedLocale;
  currentPath?: string;
  brandSubtitle: string;
  languageLinks: LanguageLink[];
}

const { nav, lang = 'en', currentPath = '/', brandSubtitle, languageLinks } = Astro.props;
const homeHref = getLocaleHomePath(lang);
const copy = localeCopy[lang];
const chromeCopy = copy.chrome;
const siteName = copy.common.site.name;
const primaryNav = nav.filter((item) => item.group !== 'repo');
const repoNav = nav.filter((item) => item.group === 'repo');
---

<header class="site-header">
  <div class="container shell-panel header-panel">
    <a class="brand-mark" href={homeHref}>
      <img class="brand-logo" src="/logo.png" alt="HagiCode" width="32" height="32" />
      <span class="brand-copy">
        <strong class="brand-copy-full">{siteName}</strong>
        <strong class="brand-copy-compact">{chromeCopy.mobileBrandLabel}</strong>
        <small>{brandSubtitle}</small>
      </span>
    </a>

    <nav class="site-nav site-nav-primary" aria-label={chromeCopy.primaryNavigationLabel}>
      {primaryNav.map((item) => {
        const active = item.href === currentPath;
        const external = item.href.startsWith('http');

        return (
          <a
            href={item.href}
            class:list={['site-nav-link', { active }]}
            target={external ? '_blank' : undefined}
            rel={external ? 'noreferrer' : undefined}
          >
            <span class="site-nav-link-label site-nav-link-label-full">{item.label}</span>
            <span class="site-nav-link-label site-nav-link-label-compact">
              {item.shortLabel ?? item.label}
            </span>
          </a>
        );
      })}
    </nav>

    <nav class="site-nav site-nav-repo" aria-label={chromeCopy.utilityLabel}>
      {repoNav.map((item) => (
        <a href={item.href} class="site-nav-link" target="_blank" rel="noreferrer">
          <span class="site-nav-link-label site-nav-link-label-full">{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <div class="language-select-shell">
        <select
          class="language-select"
          name="locale"
          aria-label={chromeCopy.languageSwitcherLabel}
          data-language-select
        >
          {languageLinks.map((item) => (
            <option
              value={item.href}
              selected={item.locale === lang}
              lang={item.htmlLang}
            >
              {item.label}
            </option>
          ))}
        </select>
        <span class="language-select-icon" aria-hidden="true">▾</span>
      </div>

      <ThemeToggle locale={lang} client:load />
    </div>

    <details class="header-utility">
      <summary class="header-utility-trigger" aria-label={chromeCopy.utilityLabel}>
        <span class="header-utility-trigger-label" aria-hidden="true">
          ≡
        </span>
      </summary>
      <div class="header-utility-surface" aria-label={chromeCopy.utilityLabel}>
        {repoNav.map((item) => (
          <a href={item.href} class="site-nav-link header-utility-link" target="_blank" rel="noreferrer">
            {item.label}
          </a>
        ))}
      </div>
    </details>
  </div>
</header>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-language-select]').forEach((element) => {
      if (!(element instanceof HTMLSelectElement) || element.dataset.bound === 'true') {
        return;
      }

      element.dataset.bound = 'true';
      element.addEventListener('change', () => {
        const href = element.value;
        if (!href) {
          return;
        }

        const current = `${window.location.pathname}${window.location.search}${window.location.hash}`;
        if (href !== current) {
          window.location.assign(href);
        }
      });
    });
  })();
</script>
