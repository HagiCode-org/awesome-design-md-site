---
import Analytics51LA from '@/components/51LAAnalytics.astro';
import Header from '@/components/site/Header.astro';
import Footer from '@/components/site/Footer.astro';
import { PromoteCard } from '@/components/promote/PromoteCard';
import promoteCardStyles from '@/components/promote/PromoteCard.module.css';
import {
  getFooterLinks,
  getFooterMetaLinks,
  getGalleryNav,
  getAlternateOgLocales,
  getLanguageLinks,
  getSeoLocaleMetadata,
  localeCopy,
  getSiteMeta,
  toAbsoluteSiteUrl,
  type SupportedLocale,
} from '@/config/site';

interface Props {
  title: string;
  description: string;
  lang?: SupportedLocale;
  nav?: { label: string; href: string }[];
  currentPath?: string;
  imagePath?: string;
  imageAlt?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  lang = 'en',
  nav = getGalleryNav(lang),
  currentPath = '/',
  imagePath = getSiteMeta(lang).defaultSocialImagePath,
  imageAlt = title,
  structuredData,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://design.hagicode.com');
const canonicalUrl = toAbsoluteSiteUrl(currentPath, siteUrl);
const chromeCopy = localeCopy[lang].chrome;
const commonCopy = localeCopy[lang].common;
const siteMeta = getSiteMeta(lang);
const seoLocale = getSeoLocaleMetadata(lang);
const languageLinks = getLanguageLinks(currentPath);
const alternateLanguageLinks = languageLinks.map((item) => ({
  ...item,
  href: toAbsoluteSiteUrl(item.href, siteUrl),
}));
const footerLinks = getFooterLinks(lang);
const footerMetaLinks = getFooterMetaLinks(lang);
const xDefaultHref =
  alternateLanguageLinks.find((item) => item.locale === 'en')?.href ?? canonicalUrl;
const ogLocale = seoLocale.ogLocale;
const alternateOgLocales = getAlternateOgLocales(lang);
const socialImageUrl = toAbsoluteSiteUrl(imagePath, siteUrl);
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const pageStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalUrl,
  inLanguage: seoLocale.htmlLang,
  image: socialImageUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: siteMeta.name,
    url: toAbsoluteSiteUrl('/', siteUrl),
  },
};
---

<!doctype html>
<html lang={seoLocale.htmlLang} dir={seoLocale.direction} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/global.css" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLanguageLinks.map((item) => (
      <link rel="alternate" hreflang={item.hreflang} href={item.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:locale" content={ogLocale} />
    {alternateOgLocales.map((locale) => (
      <meta property="og:locale:alternate" content={locale} />
    ))}
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="3137" />
    <meta property="og:image:height" content="1235" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(pageStructuredData)} />
    {structuredDataItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('adms-theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (systemDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{chromeCopy.skipToContent}</a>
    <div class="page-shell">
      <Header
        lang={lang}
        nav={nav}
        currentPath={currentPath}
        brandSubtitle={chromeCopy.brandSubtitle}
        languageLinks={languageLinks}
      />
      <main id="main">
        <slot />
      </main>
      <PromoteCard locale={lang} className={promoteCardStyles.promoteCard} client:load />
      <Footer
        copy={chromeCopy.footerCopy}
        links={footerLinks}
        metaLinks={footerMetaLinks}
        siteName={commonCopy.site.name}
        directoryLabel={commonCopy.footer.relatedSites}
      />
    </div>
    <Analytics51LA />
  </body>
</html>
