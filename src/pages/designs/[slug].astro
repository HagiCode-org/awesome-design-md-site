---
import DesignDetailPage from '@/components/gallery/DesignDetailPage.astro';
import { getAwesomeDesignCatalog } from '@/lib/content/awesomeDesignCatalog';

export async function getStaticPaths() {
  const catalog = await getAwesomeDesignCatalog();

  return catalog.entries.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      previous: catalog.entries[index - 1]
        ? {
            slug: catalog.entries[index - 1].slug,
            title: catalog.entries[index - 1].title,
          }
        : undefined,
      next: catalog.entries[index + 1]
        ? {
            slug: catalog.entries[index + 1].slug,
            title: catalog.entries[index + 1].title,
          }
        : undefined,
    },
  }));
}

const { entry, previous, next } = Astro.props;
---

<DesignDetailPage locale="en" entry={entry} previous={previous} next={next} />
