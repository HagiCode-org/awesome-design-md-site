---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroPanel from '@/components/sections/HeroPanel';
import FeatureGrid from '@/components/sections/FeatureGrid.astro';
import BlueprintStrip from '@/components/sections/BlueprintStrip.astro';
import { homeContent } from '@/config/site';

const content = homeContent.en;
---

<BaseLayout
  title={content.title}
  description={content.description}
  lang={content.lang}
  nav={content.nav}
  currentPath="/en/"
>
  <HeroPanel content={content} client:load />

  <FeatureGrid
    title="A starter shaped for design-heavy content sites"
    lead="Same content as the default route, kept here so `/en/` stays explicit."
    items={content.features}
  />

  <BlueprintStrip
    title="Use the template in three passes"
    lead="Stabilize the shell, replace the copy, then scale the content model."
    items={content.steps}
  />
</BaseLayout>
